<?xml version="1.0" encoding="UTF-8"?>
<!-- 镀层材质参数 - 定义哈基米保护外壳的材质规格与更换标准 -->
<!-- 镀层是保护哈基米免受污染的关键屏障，需定期维护 -->
<config version="2.0" xmlns="http://hajimi.example.org/schema">

    <!-- 材质规格 -->
    <section name="材质定义">
        <material id="MAT-001" name="钛晶复合镀层" grade="A">
            <param name="理论寿命" value="180" unit="天"/>
            <param name="抗散斑系数" value="0.95" unit="比例">
                <description>抵抗散斑污染的能力系数</description>
            </param>
            <param name="透光率" value="0.88" unit="比例">
                <description>镀层对哈基米能量的透光性能</description>
            </param>
        </material>
        <material id="MAT-002" name="碳纤编织镀层" grade="B">
            <param name="理论寿命" value="120" unit="天"/>
            <param name="抗散斑系数" value="0.82"/>
            <param name="透光率" value="0.91"/>
        </material>
        <material id="MAT-003" name="硅氧防护镀层" grade="C">
            <param name="理论寿命" value="90" unit="天"/>
            <param name="抗散斑系数" value="0.70"/>
            <param name="透光率" value="0.95"/>
        </material>
    </section>

    <!-- 镀层状态评估 -->
    <section name="状态判定标准">
        <state name="溢彩" description="镀层完好，光泽正常，可继续运行">
            <threshold field="照骨灯反射率" operator=">=" value="0.85"/>
            <threshold field="散斑附着密度" operator="&lt;" value="0.02"/>
        </state>
        <state name="微损" description="镀层轻微损伤，需关注">
            <threshold field="照骨灯反射率" operator=">=" value="0.70"/>
            <threshold field="散斑附着密度" operator="&lt;" value="0.08"/>
        </state>
        <state name="晦暗" description="镀层老化明显，需安排换羽">
            <threshold field="照骨灯反射率" operator="&lt;" value="0.70"/>
            <threshold field="清浊比影响" operator="&gt;" value="0.15"/>
        </state>
    </section>

    <!-- 更换策略 -->
    <section name="更换管理">
        <param name="换羽计划周期" value="30" unit="天">
            <description>铁匠团队定期制定换羽计划的周期，不等同于实际换羽寿命</description>
        </param>
        <param name="换羽批量上限" value="6" unit="谐振腔/批次">
            <description>单次换羽操作最多同时处理的谐振腔数量</description>
        </param>
        <param name="饱和度下降容忍" value="0.10" unit="比例">
            <description>换羽期间谐振腔饱和度允许的最大下降幅度</description>
        </param>
        <param name="换羽触发阈值" value="照骨灯反射率&lt;0.70或状态判定为晦暗" unit="规则">
            <description>出现晦暗或反射率低于阈值时立即触发换羽</description>
        </param>
        <rule id="BONE-001" priority="1">
            <condition field="照骨灯检测" operator="==" threshold="结构性损伤">
                <description>照骨灯检测到结构性损伤时跳过换羽直接触发换骨</description>
            </condition>
            <action type="换骨" target="铁匠团队">
                <param name="紧急程度" value="立即"/>
            </action>
        </rule>
        <rule id="MOLT-001" priority="2">
            <condition field="镀层状态" operator="==" threshold="晦暗">
                <description>镀层进入晦暗状态时直接执行换羽</description>
            </condition>
            <action type="换羽" target="铁匠团队">
                <param name="紧急程度" value="高"/>
            </action>
        </rule>
    </section>

</config>
