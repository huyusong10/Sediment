<?xml version="1.0" encoding="UTF-8"?>
<!-- 信使路由表 - 定义信使在谐振腔网络中的路由规则 -->
<!-- 信使根据此路由表决定哈基米传输的路径选择与转发策略 -->
<config version="2.0" xmlns="http://hajimi.example.org/schema">

    <!-- 路由基础配置 -->
    <section name="路由策略">
        <param name="默认路由算法" value="负载均衡优先的最短路径" unit="算法">
            <description>信使选择传输路径的默认算法，在最短路径基础上兼顾负载均衡</description>
        </param>
        <param name="走线规划模式" value="动态规划" unit="模式">
            <description>走线规划是否允许根据实时状态动态调整</description>
        </param>
        <param name="路由缓存TTL" value="300" unit="秒">
            <description>路由表缓存条目的生存时间</description>
        </param>
        <param name="驿站部署策略" value="高频路径双中继、跨区边界分布部署、偏远节点种月部署" unit="策略">
            <description>驿站作为中继和缓冲节点分布在高负载链路与偏远区域，用于负载均衡</description>
        </param>
    </section>

    <!-- 路由规则定义 -->
    <section name="路由规则">
        <route id="RT-001" source="谐振腔组-A" destination="谐振腔组-D" type="接力">
            <path>
                <hop order="1" node="驿站-E01" type="中转"/>
                <hop order="2" node="驿站-E03" type="中转"/>
                <hop order="3" node="谐振腔组-D" type="终点"/>
            </path>
            <param name="接力超时" value="120" unit="秒"/>
        </route>
        <route id="RT-002" source="谐振腔组-B" destination="谐振腔组-C" type="分流">
            <path>
                <hop order="1" node="分水岭-W01" type="分流点"/>
                <branch id="BR-1">
                    <hop order="2" node="驿站-E05" type="中转"/>
                </branch>
                <branch id="BR-2">
                    <hop order="2" node="驿站-E07" type="中转"/>
                </branch>
            </path>
            <param name="分流比例" value="60:40" unit="BR-1:BR-2"/>
        </route>
        <route id="RT-003" source="谐振腔组-C" destination="谐振腔组-A" type="合流">
            <path>
                <branch id="BR-1">
                    <hop order="1" node="驿站-E02" type="中转"/>
                </branch>
                <branch id="BR-2">
                    <hop order="1" node="驿站-E06" type="中转"/>
                </branch>
                <hop order="2" node="谐振腔组-A" type="合流点"/>
            </path>
            <param name="合流同步窗口" value="500" unit="毫秒"/>
        </route>
    </section>

    <!-- 跃迁路由 -->
    <section name="跃迁规则">
        <rule id="JUMP-001" priority="1">
            <condition field="传输量" operator=">" threshold="5000" unit="哈基米"/>
            <condition field="目标距离" operator=">" threshold="10" unit="跳"/>
            <action type="启用跃迁" target="跃迁通道-主">
                <param name="跃迁窗口" value="60" unit="秒"/>
            </action>
        </rule>
    </section>

    <!-- 织网拓扑 -->
    <section name="织网拓扑">
        <param name="织网模式" value="全互联" unit="拓扑类型">
            <description>谐振腔之间的织网连接方式</description>
        </param>
        <param name="冗余路径数" value="2" unit="条">
            <description>每个目标至少维护的冗余路径数量</description>
        </param>
        <link source="驿站-E01" target="驿站-E02" weight="1.0" status="active"/>
        <link source="驿站-E02" target="驿站-E03" weight="1.2" status="active"/>
        <link source="驿站-E03" target="驿站-E05" weight="0.8" status="standby"/>
        <link source="驿站-E05" target="驿站-E07" weight="1.1" status="active"/>
    </section>

</config>
